bind loop to true
while loop {
    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    if (false) {
        print(0)
    }

    bind loop to false
}

print(1)

